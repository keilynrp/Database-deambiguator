# ─────────────────────────────────────────────────────────────
# UKIP Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# ── Authentication ──────────────────────────────────────────
# Admin credentials for the single-user JWT login
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# JWT signing key — use a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Token lifetime in minutes (default: 480 = 8 hours)
JWT_EXPIRE_MINUTES=480

# ── Credential Encryption ───────────────────────────────────
# Fernet key for encrypting API keys/secrets stored in the database.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to skip encryption (DEV ONLY — do NOT use in production).
ENCRYPTION_KEY=

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3004,http://localhost:3000

# ── Database ────────────────────────────────────────────────
# PostgreSQL-first default for local and deployment-oriented environments.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ukip
POSTGRES_USER=ukip
POSTGRES_PASSWORD=ukip_secret
DATABASE_URL=postgresql+psycopg2://ukip:ukip_secret@127.0.0.1:5432/ukip

# Optional local SQLite fallback for compatibility-only scenarios.
# UKIP_DB_MODE=sqlite
# SQLITE_DATABASE_URL=sqlite:///./sql_app.db

# PostgreSQL/MySQL Pool Settings (ignored for SQLite fallback)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Session Cookie (separate from JWT for defense-in-depth) ─
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# ── External Enrichment APIs ────────────────────────────────
WOS_API_KEY=
OPENALEX_EMAIL=
SCOPUS_API_KEY=

# ── SSO / OAuth2 (optional — leave blank to disable SSO button) ─
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_METADATA_URL=

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# Explicit opt-in only. Keep Sentry disabled unless intentionally enabled.
SENTRY_ENABLED=0
SENTRY_DSN=

# Tracing stays off even when Sentry is enabled until you opt in separately.
SENTRY_ENABLE_TRACING=0
SENTRY_TRACES_SAMPLE_RATE=0.0

# Conservative defaults to avoid surprise data capture.
SENTRY_SEND_DEFAULT_PII=0
SENTRY_RELEASE=
SENTRY_DEBUG=0
